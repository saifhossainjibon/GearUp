model User {
    id        String       @id @default(uuid())
    name      String       @db.VarChar(255)
    email     String       @unique
    phone     String?
    password  String
    status    ActiveStatus @default(ACTIVE)
    role      Role
    createdAt DateTime     @default(now())
    updatedAt DateTime     @updatedAt

    @@map("users")
}
